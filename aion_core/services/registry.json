{
  "_readme": "Services AION-Core — scripts Python executes directement, pas de port separé.",
  "_branch": "main",
  "_install": "git cherry-pick <commit_sha>  ou  POST /api/services/install",
  "version": "1.0",
  "services": {
    "capacity_calc": {
      "name": "capacity_calc",
      "description": "Calcul de charge projet",
      "file": "aion_core/services/builtins/capacity_calc.py",
      "builtin": true,
      "status": "active",
      "actions": [
        "calculate",
        "help"
      ]
    },
    "git_status": {
      "name": "git_status",
      "description": "Statut git de tous les repos AION_APPS",
      "file": "aion_core/services/builtins/git_status.py",
      "builtin": true,
      "status": "active",
      "actions": [
        "status"
      ]
    },
    "env_checker": {
      "name": "env_checker",
      "description": "Verification des .env - cles manquantes",
      "file": "aion_core/services/builtins/env_checker.py",
      "builtin": true,
      "status": "active",
      "actions": [
        "check"
      ]
    },
    "ado_search": {
      "name": "ado_search",
      "description": "Recherche work items Azure DevOps",
      "file": "aion_core/services/builtins/ado_search.py",
      "builtin": true,
      "status": "active",
      "actions": [
        "search"
      ]
    }
  }
}