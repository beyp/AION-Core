

# ── AION Auto-Update ──────────────────────────────────────────────────────────
# Mode de mise a jour automatique de AION-Core
# "notify" : affiche une banniere dans le dashboard (recommande)
# "auto"   : applique et redemarre automatiquement (attention !)
AION_UPDATE_MODE=notify

# Intervalle de verification en secondes (defaut: 3600 = 1 heure)
AION_UPDATE_INTERVAL=3600
