{
  "_readme": "Copier en apps.local.json (git-ignored). Config de tes apps personnelles.",
  "_standard": {
    "note": "Toute app AION-Core doit respecter : entry point unique, /health endpoint, port via env var.",
    "modes": {
      "fastapi": "App web FastAPI/uvicorn — lancee par python run_api.py ou python main.py",
      "script": "Script Python natif (Desktop/Tkinter) — AION lance la fenetre, pas d'iframe",
      "docker": "Container Docker — AION fait docker compose up -d"
    }
  },
  "_important": {
    "QuickMind_entry": "run_api.py — lance core.api_server:app (FastAPI headless, port 8765)",
    "QuickMind_DB": "config.yaml -> database.path. Copier config.yaml dans appdata/ pour persister.",
    "ProjectMind_entry": "main.py — FastAPI natif avec if __name__ block (port 8766)",
    "ProjectMind_DB": "Variable DB_PATH dans .env -> C:/AION_APPS/appdata/projectmind/projectmind.db",
    "shared_keys": "Déclarer les clés partagées avec AION-Core dans 'shared_keys'. Celles-ci peuvent être héritées depuis data/shared.env via le bouton Hériter dans Config."
  },
  "version": "1.0",
  "apps": {
    "quickmind": {
      "name": "QuickMind",
      "description": "Gestionnaire de taches — API FastAPI headless (run_api.py)",
      "type": "fastapi",
      "status": "installed",
      "connector": "aion_core/apps/quickmind/connector.py",
      "url": "http://localhost:8765",
      "health_endpoint": "/health",
      "github": "beyp/QuickMind",
      "icon": "check",
      "version": "1.0",
      "autostart": {
        "enabled": true,
        "mode": "fastapi",
        "path": "C:\\code\\Python\\QuickMind",
        "command": [
          "C:\\Code\\Python\\QuickMind\\.venv\\Scripts\\python.exe",
          "run_api.py"
        ],
        "port": 8765,
        "startup_order": 1,
        "health_check": true,
        "env": {
          "QUICKMIND_HOST": "0.0.0.0",
          "QUICKMIND_PORT": "8765"
        }
      },
      "store": {
        "install_path": "C:\\Code\\Python\\QuickMind",
        "appdata_path": "C:\\AION_APPS\\appdata\\quickmind",
        "appdata_files": [
          "data/quickmind.db",
          "data/attachments",
          "config.yaml"
        ],
        "github": "beyp/QuickMind",
        "installed_at": "",
        "last_update": ""
      },
      "shared_keys": [
        "GROQ_API_KEY",
        "GROQ_MODEL"
      ]
    },
    "projectmind": {
      "name": "ProjectMind",
      "description": "Gestion de projets Gantt/capacity — FastAPI natif (main.py)",
      "type": "fastapi",
      "status": "installed",
      "connector": null,
      "url": "http://localhost:8766",
      "health_endpoint": "/health",
      "github": "beyp/ProjectMind",
      "icon": "clipboard",
      "version": "1.0",
      "autostart": {
        "enabled": true,
        "mode": "fastapi",
        "path": "C:\\Code\\Python\\ProjectMind",
        "command": [
          "C:\\Code\\Python\\ProjectMind\\.venv\\Scripts\\python.exe",
          "main.py"
        ],
        "port": 8766,
        "startup_order": 2,
        "health_check": true,
        "env": {
          "PROJECTMIND_HOST": "0.0.0.0",
          "PROJECTMIND_PORT": "8766",
          "DB_PATH": "C:\\AION_APPS\\appdata\\projectmind\\projectmind.db",
          "GROQ_API_KEY": "",
          "GROQ_MODEL": "llama-3.3-70b-versatile"
        }
      },
      "store": {
        "install_path": "C:\\Code\\Python\\ProjectMind",
        "appdata_path": "C:\\AION_APPS\\appdata\\projectmind",
        "appdata_files": [
          "data/projectmind.db"
        ],
        "github": "beyp/ProjectMind",
        "installed_at": "",
        "last_update": ""
      },
      "shared_keys": [
        "GROQ_API_KEY",
        "GROQ_MODEL",
        "ADO_PAT",
        "ADO_ORG"
      ]
    }
  }
}