{
  "_readme": "Copier en apps.local.json — ignoré par git. Apps gérées par AION AppStore.",
  "_doc": {
    "appdata_files": "Déclarés après le premier lancement via le bouton Scan AppData.",
    "AION_DATA_DIR": "Injecté automatiquement. L'app peut utiliser os.getenv('AION_DATA_DIR').",
    "DB_PATH": "Pour ProjectMind : DB_PATH pointe vers appdata/ via .env"
  },
  "version": "1.0",
  "apps": {
    "quickmind": {
      "name": "QuickMind",
      "description": "Gestionnaire de tâches personnel",
      "type": "fastapi",
      "status": "installed",
      "connector": "aion_core/apps/quickmind/connector.py",
      "url": "http://localhost:8765",
      "health_endpoint": "/health",
      "github": "beyp/QuickMind",
      "icon": "check",
      "version": "1.0",
      "autostart": {
        "enabled": true,
        "mode": "fastapi",
        "path": "C:\\AION_APPS\\repos\\QuickMind",
        "command": [
          "C:\\AION_APPS\\repos\\QuickMind\\.venv\\Scripts\\python.exe",
          "run_api.py"
        ],
        "port": 8765,
        "startup_order": 1,
        "health_check": false,
        "env": {
          "AION_DATA_DIR": "C:\\AION_APPS\\appdata\\quickmind",
          "AION_APP_ID": "quickmind"
        }
      },
      "store": {
        "install_path": "C:\\AION_APPS\\repos\\QuickMind",
        "appdata_path": "C:\\AION_APPS\\appdata\\quickmind",
        "appdata_files": [
          "data/quickmind.db",
          "memory.json"
        ],
        "github": "beyp/QuickMind",
        "installed_at": "",
        "last_update": ""
      }
    },
    "projectmind": {
      "name": "ProjectMind",
      "description": "Gestion de projets avec Gantt, capacity planning — Docker",
      "type": "docker",
      "status": "installed",
      "connector": null,
      "url": "http://localhost:8766",
      "health_endpoint": "/api/projects",
      "github": "beyp/ProjectMind",
      "icon": "clipboard",
      "version": "1.0",
      "autostart": {
        "enabled": true,
        "mode": "docker",
        "path": "C:\\AION_APPS\\repos\\ProjectMind",
        "command": [
          "docker",
          "compose",
          "-f",
          "docker-compose.yml",
          "up",
          "-d",
          "--build"
        ],
        "port": 8766,
        "startup_order": 2,
        "health_check": false,
        "env": {
          "DB_PATH": "/app/data/projectmind.db",
          "AION_DATA_DIR": "C:\\AION_APPS\\appdata\\projectmind"
        }
      },
      "store": {
        "install_path": "C:\\AION_APPS\\repos\\ProjectMind",
        "appdata_path": "C:\\AION_APPS\\appdata\\projectmind",
        "appdata_files": [
          "data/projectmind.db"
        ],
        "github": "beyp/ProjectMind",
        "installed_at": "",
        "last_update": ""
      }
    }
  }
}