{
  "version": "1.0",
  "apps": {
    "quickmind": {
      "name": "QuickMind",
      "type": "fastapi",
      "status": "installed",
      "github": "beyp/QuickMind",
      "url": "http://localhost:8765",
      "health_endpoint": "/health",
      "icon": "check",
      "autostart": {
        "enabled": true,
        "mode": "fastapi",
        "path": "C:/code/python/QuickMind",
        "command": [
          "powershell",
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "Set-Location 'C:/code/python/QuickMind'; ./.venv/Scripts/Activate.ps1; python run_api.py"
        ],
        "port": 8765,
        "startup_order": 1,
        "health_check": false,
        "env": {
          "QUICKMIND_HOST": "0.0.0.0",
          "QUICKMIND_PORT": "8765",
          "AION_DATA_DIR": "C:/code/python/QuickMind",
          "AION_APP_ID": "quickmind"
        }
      },
      "store": {
        "install_path": "C:/code/python/QuickMind",
        "appdata_path": "C:/code/python/QuickMind",
        "appdata_files": [
          "data/quickmind.db",
          ".env",
          "config.yaml"
        ],
        "github": "beyp/QuickMind",
        "installed_at": "2026-07-01",
        "last_update": "2026-07-01"
      }
    },
    "projectmind": {
      "name": "ProjectMind",
      "type": "fastapi",
      "status": "installed",
      "github": "beyp/ProjectMind",
      "url": "http://localhost:8766",
      "health_endpoint": "/api/projects",
      "icon": "clipboard",
      "autostart": {
        "enabled": true,
        "mode": "fastapi",
        "path": "C:/code/python/ProjectMind",
        "command": [
          "powershell",
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "Set-Location 'C:/code/python/ProjectMind'; ./.venv/Scripts/Activate.ps1; python main.py"
        ],
        "port": 8766,
        "startup_order": 2,
        "health_check": false,
        "env": {
          "AION_DATA_DIR": "C:/code/python/ProjectMind",
          "AION_APP_ID": "projectmind",
          "DB_PATH": "C:/code/python/ProjectMind/data/projectmind.db"
        }
      },
      "store": {
        "install_path": "C:/code/python/ProjectMind",
        "appdata_path": "C:/code/python/ProjectMind",
        "appdata_files": [
          "data/projectmind.db",
          ".env"
        ],
        "github": "beyp/ProjectMind",
        "installed_at": "2026-07-01",
        "last_update": "2026-07-01"
      }
    }
  }
}