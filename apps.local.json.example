{
  "_readme": "Copier en apps.local.json (git-ignored). Config de tes apps personnelles.",
  "_important": {
    "QuickMind_DB": "config.yaml → database.path controle le chemin. Copier config.yaml dans appdata/ pour persister.",
    "ProjectMind_DB": "Variable DB_PATH dans .env. Pointer vers C:/AION_APPS/appdata/projectmind/projectmind.db"
  },
  "version": "1.0",
  "apps": {
    "quickmind": {
      "name": "QuickMind",
      "description": "Gestionnaire de taches — API FastAPI/uvicorn",
      "type": "fastapi",
      "status": "installed",
      "connector": "aion_core/apps/quickmind/connector.py",
      "url": "http://localhost:8765",
      "health_endpoint": "/health",
      "github": "beyp/QuickMind",
      "icon": "check",
      "version": "1.0",
      "autostart": {
        "enabled": true,
        "mode": "fastapi",
        "path": "C:\\AION_APPS\\repos\\QuickMind",
        "command": [
          "C:\\AION_APPS\\repos\\QuickMind\\.venv\\Scripts\\python.exe",
          "run_api.py"
        ],
        "port": 8765,
        "startup_order": 1,
        "health_check": false,
        "env": {
          "QUICKMIND_HOST": "0.0.0.0",
          "QUICKMIND_PORT": "8765"
        }
      },
      "store": {
        "install_path": "C:\\AION_APPS\\repos\\QuickMind",
        "appdata_path": "C:\\AION_APPS\\appdata\\quickmind",
        "appdata_files": [
          "data/quickmind.db",
          "data/attachments",
          "config.yaml"
        ],
        "github": "beyp/QuickMind",
        "installed_at": "",
        "last_update": ""
      }
    },
    "projectmind": {
      "name": "ProjectMind",
      "description": "Gestion de projets Gantt/capacity — FastAPI natif",
      "type": "fastapi",
      "status": "installed",
      "connector": null,
      "url": "http://localhost:8766",
      "health_endpoint": "/api/projects",
      "github": "beyp/ProjectMind",
      "icon": "clipboard",
      "version": "1.0",
      "autostart": {
        "enabled": true,
        "mode": "fastapi",
        "path": "C:\\AION_APPS\\repos\\ProjectMind",
        "command": [
          "C:\\AION_APPS\\repos\\ProjectMind\\.venv\\Scripts\\python.exe",
          "main.py"
        ],
        "port": 8766,
        "startup_order": 2,
        "health_check": false,
        "env": {
          "DB_PATH": "C:\\AION_APPS\\appdata\\projectmind\\projectmind.db"
        }
      },
      "store": {
        "install_path": "C:\\AION_APPS\\repos\\ProjectMind",
        "appdata_path": "C:\\AION_APPS\\appdata\\projectmind",
        "appdata_files": [
          "data/projectmind.db"
        ],
        "github": "beyp/ProjectMind",
        "installed_at": "",
        "last_update": ""
      }
    }
  }
}